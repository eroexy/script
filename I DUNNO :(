--// local player toy container

local function GetToyContainer()
	if Workspace.PlotItems.PlayersInPlots:FindFirstChild(player.Name) then
		for _, plot in pairs(Workspace.Plots:GetChildren()) do
			local owners = plot:FindFirstChild("PlotSign") and plot.PlotSign:FindFirstChild("ThisPlotsOwners")
			if owners then
				for _, v in pairs(owners:GetChildren()) do
					if v.Value == player.Name then
						return Workspace.PlotItems:FindFirstChild(plot.Name)
					end
				end
			end
		end
	end
	return Workspace:FindFirstChild(player.Name .. "SpawnedInToys")
end

