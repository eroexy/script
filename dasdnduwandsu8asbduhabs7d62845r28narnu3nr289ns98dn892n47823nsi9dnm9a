local HOVER_HEIGHT = 17
local MAX_DISTANCE = 25
local OWNERSHIP_RANGE = 20

_G.GRAB_RATE = 0.001
_G.DESTROY_RATE = 0.0001
_G.LoopKickOwnershipToggle = false

local targetHRP = nil
local currentTargetPlr = nil
local isGrabbing = false
local savedPos = nil

local grabConnection = nil
local mainLoopRunning = false

local lastGrab = 0
local lastDestroy = 0

local function isInPlot(plr)
    local folder = workspace:FindFirstChild("PlotItems")
    if not folder then return false end

    local playersInPlots = folder:FindFirstChild("PlayersInPlots")
    if not playersInPlots then return false end

    return playersInPlots:FindFirstChild(plr.Name) ~= nil
end

local function ownsHead(char)
    local head = char and char:FindFirstChild("Head")
    if not head then return false end
    local owner = head:FindFirstChild("PartOwner")
    return owner and owner.Value == player.Name
end

local function updateSavedPosition()
    if hrp then
        savedPos = hrp.CFrame
    end
end

local function stopGrabLoop()
    if grabConnection then
        grabConnection:Disconnect()
        grabConnection = nil
    end
end

local function isTargetValid()
    if not currentTargetPlr then return false end
    if not currentTargetPlr.Parent then return false end

    local char = currentTargetPlr.Character
    if not char then return false end

    local hum = char:FindFirstChild("Humanoid")
    local tHRP = char:FindFirstChild("HumanoidRootPart")

    if not hum or hum.Health <= 0 then return false end
    if not tHRP then return false end
    if isInPlot(currentTargetPlr) then return false end

    return true
end

local function releaseTarget(skipReturn)
    if targetHRP and targetHRP.Parent then
        local hum = targetHRP.Parent:FindFirstChild("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.Sit = false
        end
    end

    stopGrabLoop()

    isGrabbing = false
    targetHRP = nil
    currentTargetPlr = nil

    if not skipReturn and hrp and savedPos then
        hrp.CFrame = savedPos
    end
end

--// GRAB LOOP
local function startGrabLoop()
    if grabConnection then return end

    grabConnection = RunService.Stepped:Connect(function()
        if not isGrabbing or not isTargetValid() then
            releaseTarget(true)
            return
        end

        if not targetHRP or not targetHRP.Parent or not hrp then
            releaseTarget(true)
            return
        end

        local distance = (targetHRP.Position - hrp.Position).Magnitude
        if distance > MAX_DISTANCE then return end

        local char = targetHRP.Parent
        local hum = char:FindFirstChild("Humanoid")

        if not ownsHead(char) then
            pcall(function()
                SetOwner:FireServer(targetHRP, targetHRP.CFrame)
            end)
            return
        end

        local lockPos = hrp.CFrame * CFrame.new(0, HOVER_HEIGHT, 0)

        if (targetHRP.Position - lockPos.Position).Magnitude > 2 then
            targetHRP.CFrame = lockPos
        end

        targetHRP.AssemblyLinearVelocity = Vector3.zero
        targetHRP.AssemblyAngularVelocity = Vector3.zero

        if hum then
            hum.PlatformStand = true
            hum.Sit = false
        end

        local now = os.clock()

        if not isTargetValid() then
            releaseTarget(true)
            return
        end

        if now - lastGrab >= _G.GRAB_RATE then
            pcall(function()
                SetOwner:FireServer(targetHRP, lockPos)
                CreateLine:FireServer(targetHRP, Vector3.zero, targetHRP.Position, false)
            end)
            lastGrab = now
        end

        if now - lastDestroy >= _G.DESTROY_RATE then
            pcall(function()
                DestroyLine:FireServer(targetHRP)
                CreateLine:FireServer(targetHRP, Vector3.zero, targetHRP.Position, false)
            end)
            lastDestroy = now
        end
    end)
end

--// INITIAL GRAB
local function grabPlayer(plr)
    if not plr or not plr.Character then return end

    releaseTarget(true)

    local char = plr.Character
    local tHRP = char:FindFirstChild("HumanoidRootPart")
    if not tHRP then return end

    updateSavedPosition()
    local mySaved = savedPos

    currentTargetPlr = plr

    local distance = (tHRP.Position - hrp.Position).Magnitude

    if distance <= OWNERSHIP_RANGE then
        for i = 1, 10 do
            pcall(function()
                SetOwner:FireServer(tHRP, tHRP.CFrame)
                CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
            end)
            task.wait(0.005)
        end
    else
        while _G.LoopKickOwnershipToggle and not ownsHead(char) do
            if not tHRP.Parent then return end

            hrp.CFrame = tHRP.CFrame * CFrame.new(3, 0, 0)

            pcall(function()
                SetOwner:FireServer(tHRP, tHRP.CFrame)
                CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
            end)

            task.wait(0.005)
        end
    end

    if not _G.LoopKickOwnershipToggle then return end

    local lockPos = mySaved * CFrame.new(0, HOVER_HEIGHT, 0)

    tHRP.CFrame = lockPos
    tHRP.AssemblyLinearVelocity = Vector3.zero

    for i = 1, 8 do
        pcall(function()
            SetOwner:FireServer(tHRP, lockPos)
            CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
        end)
        task.wait(0.005)
    end

    hrp.CFrame = mySaved

    targetHRP = tHRP
    isGrabbing = true

    startGrabLoop()
end

local function startMainLoop()
    if mainLoopRunning then return end
    mainLoopRunning = true

    task.spawn(function()
        while _G.LoopKickOwnershipToggle do
            task.wait(0.1)

            if not Target then continue end

            local plr
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Name == Target or p.DisplayName == Target then
                    plr = p
                    break
                end
            end

            if not plr then
                releaseTarget(true)
                continue
            end

            if isInPlot(plr) then
                releaseTarget(true)
                continue
            end

            local char = plr.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local tHRP = char and char:FindFirstChild("HumanoidRootPart")

            if not char or not hum or hum.Health <= 0 or not tHRP then
                releaseTarget(true)

                repeat
                    task.wait(0.5)
                    char = plr.Character
                    hum = char and char:FindFirstChild("Humanoid")
                until not _G.LoopKickOwnershipToggle or (hum and hum.Health > 0)

                continue
            end

            if not isGrabbing then
                updateSavedPosition()
                grabPlayer(plr)
            end

            if isGrabbing and not isTargetValid() then
                releaseTarget(true)
            end
        end

        mainLoopRunning = false
    end)
end

