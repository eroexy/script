local AntiBlobmanToggle = false
local connections = {}

local function processBlobman(blobman, state)
    if blobman.Name ~= "CreatureBlobman" then return end

    for _, detector in ipairs(blobman:GetChildren()) do
        if detector.Name == "LeftDetector" or detector.Name == "RightDetector" then
            for _, obj in ipairs(detector:GetChildren()) do
                if obj.Name == "LeftWeld"
                or obj.Name == "RightWeld"
                or obj.Name == "RightAlignOrientation"
                or obj.Name == "LeftAlignOrientation" then
                    obj.Enabled = not state
                end
            end
        end
    end
end

local function applyToAll(state)
    for _, plr in ipairs(Players:GetPlayers()) do
        local folder = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
        if not folder then continue end

        for _, blobman in ipairs(folder:GetChildren()) do
            processBlobman(blobman, state)
        end
    end
end

local function setupListeners()
    for _, conn in ipairs(connections) do
        conn:Disconnect()
    end
    table.clear(connections)

    for _, plr in ipairs(Players:GetPlayers()) do
        local folder = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
        if not folder then continue end

        local conn = folder.ChildAdded:Connect(function(child)
            task.wait()
            processBlobman(child, AntiBlobmanToggle)
        end)

        table.insert(connections, conn)
    end
end

