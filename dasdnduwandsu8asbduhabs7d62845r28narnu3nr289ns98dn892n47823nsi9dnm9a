local LoopBringToggle = false
local LoopBringConnection = nil
local LoopBringToken = 0

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getHRP()
	local char = getCharacter()
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function getBlobman()
	local char = getCharacter()
	local hum = char and char:FindFirstChild("Humanoid")
	return hum and hum.SeatPart and hum.SeatPart.Parent or nil
end

local function grabOnce(blob, hrp)
	local seatScript = blob:FindFirstChild("BlobmanSeatAndOwnerScript")
	local grabEvent = seatScript and seatScript:FindFirstChild("CreatureGrab")
	if not grabEvent then return end

	for _, side in ipairs({"LeftDetector", "RightDetector"}) do
		local detector = blob:FindFirstChild(side)
		local weld = detector and (detector:FindFirstChild("LeftWeld") or detector:FindFirstChild("RightWeld"))

		if detector and weld then
			grabEvent:FireServer(detector, hrp, weld)
			return
		end
	end
end

local function bringTarget(targetPlayer)
	if not targetPlayer then return end

	local myHRP = getHRP()
	if not myHRP then return end

	local originalCFrame = myHRP.CFrame

	local currentBlob = getBlobman()
	if not currentBlob then
		SpawnAndSeatBlobman()
		repeat task.wait() until getBlobman()
		currentBlob = getBlobman()
	end

	task.spawn(function()
		local targetHRP = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
		local myHRPNow = getHRP()

		if not targetHRP or not myHRPNow then
			local hrp = getHRP()
			if hrp then hrp.CFrame = originalCFrame end
			return
		end

		local dist = (myHRPNow.Position - targetHRP.Position).Magnitude

		if dist > 40 then
			myHRPNow.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2)
			task.wait()
		end

		for i = 1, 8 do
			if not currentBlob or not currentBlob.Parent then break end
			grabOnce(currentBlob, targetHRP)
			task.wait(0.02)
		end

		local finalHRP = getHRP()
		if finalHRP then
			finalHRP.CFrame = originalCFrame
		end
	end)
end

