-- Loop Kill ownership
-->>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

_G.LoopKillOwnershipToggle = false
_G.LoopKillAllOwnershipToggle = false

local currentTargetPlr = nil
local targetHRP = nil
local isGrabbing = false
local savedPos = nil
local mainLoopRunning = false

local KILL_DISTANCE = 6
local TARGET_DISTANCE = 2000

local function updateSavedPosition()
	if hrp and hrp.Parent then
		savedPos = hrp.CFrame
	end
end

local function isInPlot(plr)
	local folder = Workspace:FindFirstChild("PlotItems")
	if not folder then return false end
	local playersInPlots = folder:FindFirstChild("PlayersInPlots")
	if not playersInPlots then return false end
	return playersInPlots:FindFirstChild(plr.Name) ~= nil
end

local function isTargetWorthTracking(plr)
	if not plr or not plr.Character then return false end

	local char = plr.Character
	local hrpT = char:FindFirstChild("HumanoidRootPart")

	if not hrpT then return false end
	if isInPlot(plr) then return false end

	local myHRP = hrp
	if not myHRP then return false end

	local dist = (hrpT.Position - myHRP.Position).Magnitude
	return dist <= TARGET_DISTANCE
end

local function getClosestEligiblePlayer()
	local myHRP = hrp
	if not myHRP then return nil end

	local closest = nil
	local closestDist = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then

			-- FIX: name-based whitelist check
			if WhitelistPlayers and WhitelistPlayers[plr.Name] then
				continue
			end

			if isTargetWorthTracking(plr) then
				local char = plr.Character
				local tHRP = char and char:FindFirstChild("HumanoidRootPart")

				if tHRP then
					local dist = (tHRP.Position - myHRP.Position).Magnitude

					if dist < closestDist then
						closest = plr
						closestDist = dist
					end
				end
			end
		end
	end

	return closest
end

local function releaseTarget()
	if targetHRP and targetHRP.Parent then
		local hum = targetHRP.Parent:FindFirstChild("Humanoid")
		if hum then
			hum.PlatformStand = false
			hum.Sit = false
		end
	end

	isGrabbing = false
	targetHRP = nil
	currentTargetPlr = nil
end

local function releaseTargetAll()
	releaseTarget()
end

local function GetTarget(plr)
	if not plr or not plr.Character then
		isGrabbing = false
		return
	end

	local tChar = plr.Character
	local tHRP = tChar:FindFirstChild("HumanoidRootPart")
	if not tHRP then
		isGrabbing = false
		return
	end

	updateSavedPosition()
	local mySaved = savedPos

	currentTargetPlr = plr
	targetHRP = tHRP

	local distance = (tHRP.Position - hrp.Position).Magnitude
	local start = tick()

	while _G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle do
		if distance <= KILL_DISTANCE then break end
		if not tHRP.Parent then break end

		hrp.CFrame = tHRP.CFrame
		distance = (tHRP.Position - hrp.Position).Magnitude

		if tick() - start > 0.35 then break end
		task.wait()
	end

	if not (_G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle) or not tHRP.Parent then
		isGrabbing = false
		return
	end

	task.wait(0.08)

	for i = 1, 16 do
		pcall(function()
			SetOwner:FireServer(tHRP, tHRP.CFrame)
			CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
		end)
		task.wait(0.01)
	end

	if not (_G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle) then
		isGrabbing = false
		return
	end

	local lockPos = mySaved * CFrame.new(0, 1e18, 0)
	tHRP.CFrame = lockPos
	tHRP.AssemblyLinearVelocity = Vector3.zero
	tHRP.AssemblyAngularVelocity = Vector3.zero

	pcall(function()
		DestroyLine:FireServer(tHRP)
		CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
	end)

	task.wait()

	local tHum = tChar:FindFirstChild("Humanoid")
	if tHum then
		tHum.BreakJointsOnDeath = false
		task.wait()
		tHum.Health = 0
	end

	if hrp and mySaved then
		hrp.CFrame = mySaved
	end

	releaseTarget()
end

local function StartLoopKill()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKillOwnershipToggle do
			task.wait()

			if not Target then continue end

			local plr = nil
			for _, p in ipairs(Players:GetPlayers()) do
				if p.Name == Target or p.DisplayName == Target then
					plr = p
					break
				end
			end

			if not plr or plr == player or isInPlot(plr) then
				releaseTarget()
				continue
			end

			if not isTargetWorthTracking(plr) then
				releaseTarget()
				continue
			end

			local tChar = plr.Character
			local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")

			if not tChar or not tHRP then
				releaseTarget()
				continue
			end

			if not isGrabbing then
				isGrabbing = true
				GetTarget(plr)
			end
		end

		releaseTarget()
		mainLoopRunning = false
	end)
end

local function StartLoopKillAll()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKillAllOwnershipToggle do
			task.wait(0.005)

			if isGrabbing then continue end

			local plr = getClosestEligiblePlayer()
			if not plr then continue end

			isGrabbing = true
			GetTarget(plr)
		end

		releaseTargetAll()
		mainLoopRunning = false
	end)
end

