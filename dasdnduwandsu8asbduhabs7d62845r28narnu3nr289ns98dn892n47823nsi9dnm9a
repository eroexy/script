_G.AntiInputToggle = false
_G.AntiInputItem = nil

local function StartAntiInputSystem(player, Workspace, Spawn, Destroy)
	task.spawn(function()
		local rs = RunService.RenderStepped

		while true do
			if not _G.AntiInputToggle then
				rs:Wait()
				continue
			end

			local char = player.Character
			if not char then
				rs:Wait()
				continue
			end

			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hrp then
				rs:Wait()
				continue
			end

			local ToyName = _G.AntiInputItem
			if not ToyName or ToyName == "" then
				rs:Wait()
				continue
			end

			local toysFolder = Workspace:FindFirstChild(player.Name .. "SpawnedInToys")
			local toy = toysFolder and toysFolder:FindFirstChild(ToyName)

			if not toy then
				task.spawn(function()
					pcall(function()
						local spawnCF = hrp.CFrame * CFrame.new(0, 5, 0)
						Spawn:InvokeServer(ToyName, spawnCF, Vector3.new(0, 0, 0))
					end)
				end)

				local startWait = tick()
				repeat
					rs:Wait()
					toysFolder = Workspace:FindFirstChild(player.Name .. "SpawnedInToys")
					toy = toysFolder and toysFolder:FindFirstChild(ToyName)
				until toy or tick() - startWait > 1 or not _G.AntiInputToggle
			end

			if toy and toy.Parent then
				local holdPart = toy:FindFirstChild("HoldPart")
				if holdPart then
					local holdingPlayer = holdPart:FindFirstChild("HoldingPlayer")
						and holdPart.HoldingPlayer.Value

					if holdingPlayer and holdingPlayer ~= player then
						pcall(function()
							holdPart.DropItemRemoteFunction:InvokeServer(
								toy,
								hrp.CFrame * CFrame.new(0, 2000, 0),
								Vector3.new(0, 0, 0)
							)
						end)
						Destroy:FireServer(toy)
					else
						pcall(function()
							holdPart.HoldItemRemoteFunction:InvokeServer(toy, char)
						end)

						pcall(function()
							holdPart.DropItemRemoteFunction:InvokeServer(
								toy,
								hrp.CFrame * CFrame.new(0, 2000, 0),
								Vector3.new(0, 0, 0)
							)
						end)
					end
				end
			end

			rs:Wait()
		end
	end)
end

