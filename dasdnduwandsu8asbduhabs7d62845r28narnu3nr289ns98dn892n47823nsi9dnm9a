_G.ControlAll = false
_G.KillPlayersToggle = false

local TARGET_DISTANCE = 800
local Grab_DISTANCE = 40

local trackedPlayers = {}

local function trackPlayerLifecycle(plr)
	plr.CharacterAdded:Connect(function()
		trackedPlayers[plr] = nil
	end)
end

for _, plr in ipairs(Players:GetPlayers()) do
	if plr ~= player then
		trackPlayerLifecycle(plr)
	end
end

Players.PlayerAdded:Connect(function(plr)
	if plr ~= player then
		trackPlayerLifecycle(plr)
	end
end)

Players.PlayerRemoving:Connect(function(plr)
	trackedPlayers[plr] = nil
end)

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getBlobman()
	local char = getCharacter()
	local hum = char and char:FindFirstChild("Humanoid")
	return hum and hum.SeatPart and hum.SeatPart.Parent or nil
end

local function waitForBlobman()
	while _G.ControlAll do
		local b = getBlobman()
		if b then return b end
		task.wait(0.2)
	end
	return nil
end

local function GetToyContainer()
	if Workspace.PlotItems.PlayersInPlots:FindFirstChild(player.Name) then
		for _, plot in pairs(Workspace.Plots:GetChildren()) do
			local owners = plot:FindFirstChild("PlotSign") and plot.PlotSign:FindFirstChild("ThisPlotsOwners")
			if owners then
				for _, v in pairs(owners:GetChildren()) do
					if v.Value == player.Name then
						return Workspace.PlotItems:FindFirstChild(plot.Name)
					end
				end
			end
		end
	end
	return Workspace:FindFirstChild(player.Name .. "SpawnedInToys")
end

local function SpawnBlobman()
	local container = GetToyContainer()
	if not container then return end

	local cf = hrp.CFrame

	task.spawn(function()
		pcall(function()
			Spawn:InvokeServer("CreatureBlobman", cf, Vector3.zero)
		end)
	end)

	local blob = container:WaitForChild("CreatureBlobman", 2)
	if blob then
		for _, part in ipairs(blob:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end

		local seat = blob:FindFirstChild("VehicleSeat", true)
		if seat then
			hrp.CFrame = seat.CFrame * CFrame.new(0, 3, 0)
			seat:Sit(human)
		end
	end

	return blob
end

local function grabRelease(blob, targetHRP)
	local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript")
	if not script then return end

	local grab = script:FindFirstChild("CreatureGrab")
	local release = script:FindFirstChild("CreatureRelease")
	if not grab or not release then return end

	for _, side in ipairs({"Left", "Right"}) do
		local det = blob:FindFirstChild(side .. "Detector")
		local weld = det and det:FindFirstChild(side .. "Weld")
		if weld then
			grab:FireServer(nil, targetHRP, weld)
			task.wait()
			release:FireServer(weld, targetHRP)
		end
	end
end

local function attack(target, blob)
	if target == player or not target then return end

	if trackedPlayers[target] then
		return
	end

	if WhitelistPlayers and WhitelistPlayers[target.Name] then
		return
	end

	local char = target.Character
	if not char then return end

	local targetHRP = char:FindFirstChild("HumanoidRootPart")
	local targetHum = char:FindFirstChild("Humanoid")
	if not targetHRP or not targetHum then return end

	local myHRP = hrp
	if not myHRP then return end

	local dist = (myHRP.Position - targetHRP.Position).Magnitude
	if dist > TARGET_DISTANCE then return end

	hrp:PivotTo(targetHRP.CFrame * CFrame.new(0, 0, -2))
	task.wait()

	dist = (hrp.Position - targetHRP.Position).Magnitude
	if dist > Grab_DISTANCE then return end

	local didGrab = false

	for i = 1, 8 do
		if not _G.ControlAll then break end
		if not blob or not blob.Parent then break end

		grabRelease(blob, targetHRP)
		didGrab = true

		pcall(function()
			targetHum.WalkSpeed = _G.WalkSpeedBlobman or targetHum.WalkSpeed
			targetHum.JumpPower = _G.JumpPowerBlobman or targetHum.JumpPower
		end)

		task.wait(0.05)
	end

	if _G.KillPlayersToggle and didGrab then
		trackedPlayers[target] = true
	end
end

task.spawn(function()
	while true do
		if not _G.ControlAll then
			task.wait(0.05)
			continue
		end

		local blob = getBlobman() or waitForBlobman()
		if not blob then continue end

		for _, plr in ipairs(Players:GetPlayers()) do
			if not _G.ControlAll then break end
			attack(plr, blob)
		end

		task.wait(0.2)
	end
end)

task.spawn(function()
	while true do
		if _G.KillPlayersToggle then
			for plr, _ in pairs(trackedPlayers) do
				local char = plr.Character
				if char then
					local hum = char:FindFirstChild("Humanoid")
					if hum and hum.Health > 0 then
						hum.Health = 0
					end
				end
			end
		end
		task.wait(0.1)
	end
end)

