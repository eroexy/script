local function getWhitelistedPlayers()
	if not _G.WhitelistFriendsToggle then
		return nil
	end

	local whitelist = {}

	if typeof(WhitelistPlayers) == "table" then
		for _, plr in ipairs(WhitelistPlayers) do
			if typeof(plr) == "Instance" and plr:IsA("Player") then
				whitelist[plr] = true
			end
		end
	elseif typeof(WhitelistPlayers) == "Instance" and WhitelistPlayers:IsA("Player") then
		whitelist[WhitelistPlayers] = true
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local ok, isFriend = pcall(function()
				return player:IsFriendsWith(plr.UserId)
			end)

			if ok and isFriend then
				whitelist[plr] = true
			end
		end
	end

	return whitelist
end

