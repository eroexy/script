	return true
end

local function getClosestEligiblePlayerForKick()
	local myHRP = hrp
	if not myHRP then return nil end

	local closest = nil
	local closestDist = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and isTargetReady(plr) then

			if WhitelistPlayers and WhitelistPlayers[plr.Name] then
				continue
			end

			local tHRP = getHRP(plr.Character)
			if tHRP then
				local dist = (tHRP.Position - myHRP.Position).Magnitude

				if dist <= TARGET_DISTANCE and dist < closestDist then
					closest = plr
					closestDist = dist
				end
			end
		end
	end

	return closest
end

local function releaseTarget()
	if targetHRP and targetHRP.Parent then
		local hum = targetHRP.Parent:FindFirstChild("Humanoid")
		if hum then
			hum.PlatformStand = false
			hum.Sit = false
		end
	end

	isGrabbing = false
	targetHRP = nil
	currentTargetPlr = nil
end

local function releaseTargetAll()
	releaseTarget()
end

local function GetTarget(plr)
	if not plr or not plr.Character then
		releaseTarget()
		return
	end

	local tChar = plr.Character
	local tHRP = getHRP(tChar)

	if not tHRP then
		releaseTarget()
		return
	end

	currentTargetPlr = plr
	targetHRP = tHRP
	updateSavedPosition()

	local distance = (tHRP.Position - hrp.Position).Magnitude
	if distance > TARGET_DISTANCE then
		releaseTarget()
		return
	end

	local start = os.clock()

	while (_G.LoopKickV1 or _G.LoopKickAllV1) and tHRP.Parent do
		if not hrp or not hrp.Parent then break end

		hrp.CFrame = tHRP.CFrame

		if (tHRP.Position - hrp.Position).Magnitude <= KILL_DISTANCE then
			break
		end

		if os.clock() - start > 0.5 then break end
		task.wait()
	end

	if not (_G.LoopKickV1 or _G.LoopKickAllV1) or not tHRP.Parent then
		releaseTarget()
		return
	end

	task.wait(0.05)

	for i = 1, 16 do
		if not (_G.LoopKickV1 or _G.LoopKickAllV1) then break end
		pcall(function()
			SetOwner:FireServer(tHRP, tHRP.CFrame)
			CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
		end)
		task.wait(0.01)
	end

	if not (_G.LoopKickV1 or _G.LoopKickAllV1) then
		releaseTarget()
		return
	end

	local launchPos = savedPos * CFrame.new(0, 1e18, 0)

	pcall(function()
		tHRP.CFrame = launchPos
		tHRP.AssemblyLinearVelocity = Vector3.zero
		tHRP.AssemblyAngularVelocity = Vector3.zero
	end)

	pcall(function()
		DestroyLine:FireServer(tHRP)
	end)

	task.wait(0.15)

	if hrp and savedPos then
		hrp.CFrame = savedPos
	end

	releaseTarget()
end

local function StartLoopKickV1()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKickV1 do
			task.wait(0.1)

			if not hrp or not hrp.Parent then
				continue
			end

			local plr = nil

			if typeof(Target) ~= "string" then
				continue
			end

			for _, p in ipairs(Players:GetPlayers()) do
				if p.Name == Target or p.DisplayName == Target then
					plr = p
					break
				end
			end

			if not plr or plr == player then
				releaseTarget()
				continue
			end

			if isInPlot(plr) or not isTargetReady(plr) then
				releaseTarget()
				continue
			end

			local hrpT = getHRP(plr.Character)
			if not hrpT then
				releaseTarget()
				continue
			end

			local dist = (hrpT.Position - hrp.Position).Magnitude
			if dist > TARGET_DISTANCE then
				releaseTarget()
				continue
			end

			if not isGrabbing then
				isGrabbing = true
				task.spawn(function()
					GetTarget(plr)
				end)
			end
		end

		releaseTarget()
		mainLoopRunning = false
	end)
end

local function StartLoopKickAllV1()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKickAllV1 do
			task.wait(0.005)

			if isGrabbing then continue end

			local plr = getClosestEligiblePlayerForKick()
			if not plr then continue end

			isGrabbing = true
			task.spawn(function()
				GetTarget(plr)
			end)
		end

		releaseTargetAll()
		mainLoopRunning = false
	end)
end

