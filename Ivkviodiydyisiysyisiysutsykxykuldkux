local Ocean = Workspace:WaitForChild("Map"):WaitForChild("AlwaysHereTweenedObjects"):WaitForChild("Ocean"):WaitForChild("Object"):WaitForChild("ObjectModel")

local function ChangeCollisionOcean(state)
	for _, obj in ipairs(Ocean:GetChildren()) do
		if obj:IsA("BasePart") then
			obj.CanCollide = state
		end
	end
end

