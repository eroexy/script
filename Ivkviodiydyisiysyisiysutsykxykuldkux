local function validHoldModel(model)
	local hold = model:FindFirstChild("HoldPart")
	if not hold then return end

	local grab = hold:FindFirstChild("HoldItemRemoteFunction")
	local drop = hold:FindFirstChild("DropItemRemoteFunction")

	if grab and drop then
		return hold, grab, drop
	end
end

local function grabItem(model)
	local hold, grab, drop = validHoldModel(model)
	if not hold then return end

	pcall(function()
		grab:InvokeServer(model, GrabData.lp.Character)
	end)

	pcall(function()
		drop:InvokeServer(model, GrabData.dropPos, Vector3.new())
	end)
end

local function processFolder(folder)
	for _, obj in ipairs(folder:GetDescendants()) do
		if obj:IsA("Model") then
			grabItem(obj)
		end
	end
end

local function loopGrab()
	while GrabData.toggle do
		local targetPlr = getTargetPlayer()

		if targetPlr then
			local toysFolder = GrabData.ws:FindFirstChild(targetPlr.Name .. "SpawnedInToys")
			if toysFolder then
				processFolder(toysFolder)
			end

			local plotItems = GrabData.ws:FindFirstChild("PlotItems")
			if plotItems then
				local targetPlot = plotItems:FindFirstChild(targetPlr.Name)
				if targetPlot then
					for _, model in ipairs(targetPlot:GetChildren()) do
						if model:IsA("Model") then
							grabItem(model)
						end
					end
				end
			end
		end

		task.wait()
	end
end

