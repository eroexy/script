local Legs = {"Left Leg", "Right Leg", "HumanoidRootPart"}
local Arms = {"Left Arm", "Right Arm", "HumanoidRootPart"}

running = false

local function DestroyLeg()
	if running then return end
	running = true

	local char = GetGrabTarget()
	if not char then
		Orion:MakeNotification({Name = "Notification", Content = "Hold a player", Time = 3})
		running = false
		return
	end

	local head = char:FindFirstChild("Head")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not (head and hrp) then
		running = false
		return
	end

	local ball = head:FindFirstChild("BallSocketConstraint")
	if not (ball and ball.Enabled) then
		Orion:MakeNotification({Name = "Notification", Content = "Player not ragdolled", Time = 3})
		running = false
		return
	end

	local root = hrp:FindFirstChild("RootJoint") or hrp:FindFirstChildWhichIsA("Motor6D")
	local saved, disabled = hrp.CFrame, {}

	if root then
		root.Enabled = false
		table.insert(disabled, root)
	end

	for _, n in ipairs(Legs) do
		local limb = char:FindFirstChild(n)
		if limb then
			for _, d in ipairs(limb:GetDescendants()) do
				if d:IsA("WeldConstraint") then
					d.Enabled = false
					table.insert(disabled, d)
				end
			end
			limb.CFrame = CFrame.new(limb.Position.X, -1e5, limb.Position.Z)
		else 
			if not char:FindFirstChild("Left Leg") and not char:FindFirstChild("Right Leg") then
				Orion:MakeNotification({Name = "Notification", Content = "Bro is already crippled", Time = 3})
				return
			end
		end
		task.wait(0.1)
	end

	if Workspace:FindFirstChild("GrabParts") then
		Workspace.GrabParts:Destroy()
	end

	for _, v in ipairs(disabled) do
		v.Enabled = true
	end

	ReplicatedStorage.GrabEvents.DestroyGrabLine:FireServer(hrp)

	hrp.AssemblyLinearVelocity = Vector3.zero
	hrp.AssemblyAngularVelocity = Vector3.zero
	hrp.CFrame = saved

	table.clear(disabled)
	running = false
end


