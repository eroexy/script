_G.AntiGrabToggle = false
local antiGrabCon

local function startAntiGrab()
	if antiGrabCon then return end

	antiGrabCon = RunService.Heartbeat:Connect(function()
		if not _G.AntiGrabToggle then return end

		local char = player.Character
		if not char then return end

		local humanoid = char:FindFirstChild("Humanoid")
		local hrp = char:FindFirstChild("HumanoidRootPart")

		if not humanoid or not hrp then return end
		if humanoid.Health <= 0 then return end

		local held = player:FindFirstChild("IsHeld")

		if not held or not held.Value then
			hrp.Anchored = false
			return
		end

		hrp.Anchored = true
		hrp.AssemblyLinearVelocity = Vector3.zero
		hrp.AssemblyAngularVelocity = Vector3.zero

		Struggle:FireServer()
		Ragdoll:FireServer(hrp, 0)
	end)
end

local function stopAntiGrab()
	if antiGrabCon then
		antiGrabCon:Disconnect()
		antiGrabCon = nil
	end

	local char = player.Character
	if char then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.Anchored = false
		end
	end
end

player.CharacterAdded:Connect(function()
	stopAntiGrab()
	if _G.AntiGrabToggle then
		startAntiGrab()
	end
end)

task.spawn(function()
	while true do
		if _G.AntiGrabToggle then
			startAntiGrab()
		else
			stopAntiGrab()
		end
		task.wait(0.08)
	end
end)

