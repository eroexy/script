-- Blobman Kill Server
-->>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>












local function KillServer()
	local hrp = getHRP()
	if not hrp then return end

	local returnCF = hrp.CFrame * CFrame.new(0, 100, 0)

	local blob = getBlobman()
	if not blob then
		Orion:MakeNotification({Name = "Notification", Content = "Seat any blobman", Time = 5})
		return
	end

	local grabbedPlayers = {}

	local targets = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")
			if targetHRP then
				table.insert(targets, targetHRP)
			end
		end
	end

	for _, targetHRP in ipairs(targets) do
		hrp.AssemblyLinearVelocity = Vector3.zero
		hrp.AssemblyAngularVelocity = Vector3.zero
		hrp:PivotTo(targetHRP.CFrame)

		task.wait(0.05)

		for i = 1, 4 do
			if not blob or not blob.Parent then break end
			grabRelease(blob, targetHRP)
			task.wait(0.05)
		end

		table.insert(grabbedPlayers, targetHRP)
	end

	hrp:PivotTo(returnCF)

	if #grabbedPlayers > 0 then
		local center = hrp.Position
		local num = #grabbedPlayers
		local angleStep = (2 * math.pi) / num

		for i, targetHRP in ipairs(grabbedPlayers) do
			local angle = (i - 1) * angleStep

			local offset = Vector3.new(
				math.cos(angle) * 10,
				10,
				math.sin(angle) * 10
			)

			local newPos = center + offset
			local newCFrame = CFrame.lookAt(newPos, center)
			targetHRP.Anchored = true
			targetHRP:PivotTo(newCFrame)
			task.wait(0.05)
		end
	end

	for _, targetHRP in ipairs(grabbedPlayers) do
		if targetHRP and targetHRP.Parent then
			local hum = targetHRP.Parent:FindFirstChild("Humanoid")
			if hum then
				targetHRP.Anchored = false
				hum.BreakJointsOnDeath = false
				hum.Health = 0
			end
		end
	end

	hrp.Anchored = false
end

