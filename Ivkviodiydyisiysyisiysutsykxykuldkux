local function claimNetwork(root)
	for attempts = 1, 10 do
		pcall(function()
			SetOwner:FireServer(root, root.CFrame)
		end)
		task.wait(0.02)
	end
end

local function bringTarget(plr, targetCF, plotMap)
	if not plr or plr == player then return end
	if not Players:FindFirstChild(plr.Name) then
		Orion:MakeNotification({
			Name = "Damn they gone blud",
			Content = string.format("%s (@%s) is gone", plr.DisplayName, plr.Name),
			Time = 4
		})
		return
	end

	local char = plr.Character
	if not char then
		Orion:MakeNotification({
			Name = "Damn they gone blud",
			Content = string.format("%s (@%s) is gone", plr.DisplayName, plr.Name),
			Time = 4
		})
		return
	end

	if plotMap[plr.Name] then
		Orion:MakeNotification({
			Name = "Player in plot",
			Content = string.format("%s (@%s) is in a plot", plr.DisplayName, plr.Name),
			Time = 4
		})
		return
	end

	local root = getRoot(char)
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not root or not hum or hum.Health <= 0 then return end

	local myRoot = getRoot(getChar())
	if myRoot then
		pcall(function()
			myRoot.CFrame = root.CFrame * CFrame.new(0, 0, 0)
		end)
	end

	claimNetwork(root)

	pcall(function()
		if DestroyLine then
			DestroyLine:FireServer(char)
		end
	end)

	pcall(function()
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
		root.CFrame = targetCF
	end)

	pcall(function()
		if DestroyLine then
			DestroyLine:FireServer(root)
		end
	end)
end

local function executeBring(list, notifyFlag)
	local myRoot = getRoot(getChar())
	if not myRoot then return end

	local returnCF = myRoot.CFrame
	local targetCF = (saveEnabled and savedCFrame) or returnCF
	local plotMap = {}
	for _, obj in ipairs(PlayersInPlotsFolder:GetChildren()) do
		local model = obj:IsA("Model") and obj or obj:FindFirstAncestorOfClass("Model")
		if model then
			plotMap[model.Name] = true
		end
	end

	for _, plr in ipairs(list) do
		bringTarget(plr, targetCF, plotMap)
	end

	task.wait(0.03)
	local r = getRoot(getChar())
	if r then
		r.CFrame = returnCF
	end
end

