local function GetToyContainers()
	local containers = {}
	for _, plrs in ipairs(Players:GetChildren()) do
		local container = nil
		if Workspace.PlotItems.PlayersInPlots:FindFirstChild(plrs.Name) then
			for _, plot in pairs(Workspace.Plots:GetChildren()) do
				local owners = plot:FindFirstChild("PlotSign") and plot.PlotSign:FindFirstChild("ThisPlotsOwners")

				if owners then
					for _, v in pairs(owners:GetChildren()) do
						if v.Value == plrs.Name then
							container = Workspace.PlotItems:FindFirstChild(plot.Name)
							break
						end
					end
				end
			end
		end
		if not container then
			container = Workspace:FindFirstChild(plrs.Name .. "SpawnedInToys")
		end
		if container then
			table.insert(containers, container)
		end
	end
	return containers
end

local AntiStickConn

Tab:AddToggle({
	Name = "Anti-Stick",
	Color = Color3.fromRGB(93, 5, 97),
	Flag = "AntiStickToggle",
	Save = true,
	Callback = function(Value)
		_G.AntiKickOwnerToggle = Value

		if not Value then
			if AntiStickConn then
				AntiStickConn:Disconnect()
				AntiStickConn = nil
			end
			return
		end

		if AntiStickConn then
			AntiStickConn:Disconnect()
			AntiStickConn = nil
		end

		AntiStickConn = RunService.Heartbeat:Connect(function()
			if not _G.AntiKickOwnerToggle then return end

			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end

			local ToyFolders = GetToyContainers()
			local now = tick()

			for _, folder in ipairs(ToyFolders) do
				if not (folder and folder:IsA("Instance")) then continue end

				for _, toy in ipairs(folder:GetChildren()) do
					if not (toy and toy:IsA("Model")) then continue end

					local sticky = toy:FindFirstChild("StickyPart", true)
					if not (sticky and sticky:IsA("BasePart")) then continue end

					local weld = sticky:FindFirstChild("StickyWeld")
					local part1 = weld and weld.Part1
					if not (part1 and part1:IsA("BasePart")) then continue end

					local char2 = part1:FindFirstAncestorOfClass("Model")
					local player2 = char2 and Players:GetPlayerFromCharacter(char2)
					if not (player2 and player2.Name == player.Name) then continue end

					if folder.Name == player.Name .. "SpawnedInToys" or 
						(toy.Parent and toy.Parent.Name == player.Name .. "SpawnedInToys") then 
						continue 
					end

					SetOwner:FireServer(sticky, sticky.CFrame)

					task.spawn(function()
						for _, part in ipairs(toy:GetDescendants()) do
							if part:IsA("BasePart") then
								part.CanCollide = false
							end
						end

						local updatedOwner = sticky:FindFirstChild("PartOwner")
						if updatedOwner and updatedOwner.Value == player.Name then
							sticky.CFrame = CFrame.new(0, 1e18, 0)
						end
					end)
				end
			end
			task.wait(.5)
		end)
	end
