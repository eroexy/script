local function DestroyLegs()
	local char = player.Character or player.CharacterAdded:Wait()
	local human = char:WaitForChild("Humanoid")
	local hrp = char:WaitForChild("HumanoidRootPart")

	Ragdoll:FireServer(hrp, 0.6)

	task.wait(0.3)

	local limbs = { "Right Leg", "Left Leg" }
	local storedWelds = {}
	local limbParts = {}

	for _, name in ipairs(limbs) do
		local limb = char:FindFirstChild(name)
		if limb then
			table.insert(limbParts, limb)

			for _, weld in ipairs(limb:GetDescendants()) do
				if weld:IsA("WeldConstraint") then
					weld.Enabled = false
					table.insert(storedWelds, weld)
				end
			end
		end
	end

