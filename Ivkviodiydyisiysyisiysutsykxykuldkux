local function GetAllToyContainers()
	local containers = {}

	for _, plrs in ipairs(Players:GetPlayers()) do
		local container = nil

		local plotItemFolder = Workspace:FindFirstChild("PlotItems")
		local playersInPlots = plotItemFolder and plotItemFolder:FindFirstChild("PlayersInPlots")

		if playersInPlots and playersInPlots:FindFirstChild(plrs.Name) then
			for _, plot in ipairs(Workspace:FindFirstChild("Plots") and Workspace.Plots:GetChildren() or {}) do
				local sign = plot:FindFirstChild("PlotSign")
				local owners = sign and sign:FindFirstChild("ThisPlotsOwners")

				if owners then
					for _, v in ipairs(owners:GetChildren()) do
						if v.Value == plrs.Name then
							container = plotItemFolder:FindFirstChild(plot.Name)
							break
						end
					end
				end

				if container then break end
			end
		end

		if not container then
			container = Workspace:FindFirstChild(plrs.Name .. "SpawnedInToys")
		end

		if container then
			table.insert(containers, container)
		end
	end

	return containers
end

