UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if not _G.CtoGrabToggle then return end
	if input.KeyCode ~= Enum.KeyCode.C then return end

	local targetHRP, targetPlayer = getLookedAtHRP()
	local Thuman = targetHRP.Parent:FindFirstChild("Humanoid")
	if not targetHRP or not targetPlayer then return end
	
	for attempts = 1, 8 do
		SetOwner:FireServer(targetHRP, targetHRP.CFrame)
		task.wait(0.02)
	end

	if method == "Ching Chong Land" then

		task.wait(.05)
		targetHRP.CFrame = CFrame.new(591.889709, 153.338577, -92.1728058)
		task.wait(.05)
		DestroyLine:FireServer(targetHRP)
	elseif method == "Spawn Slot" then

		task.wait(.05)
		targetHRP.CFrame = CFrame.new(52.5844078, -6.11595154, -121.83712)
		task.wait(.05)
		DestroyLine:FireServer(targetHRP)
	elseif method == "Heaven" then

		task.wait(.05)
		targetHRP.CFrame = hrp.CFrame * CFrame.new(0, 1e3, 0)
		task.wait(.05)
		DestroyLine:FireServer(targetHRP)
	elseif method == "Death" then

		task.wait(.05)
		targetHRP.CFrame = hrp.CFrame * CFrame.new(0, 1e18, 0)
		task.wait(.05)
		DestroyLine:FireServer(targetHRP)
		Thuman.Health = 0
	elseif method == "Ragdoll" then
		DestroyLine:FireServer(targetHRP)
		local inv = Workspace[player.Name.."SpawnedInToys"]
		local pallet = inv:FindFirstChild("RagdollPallet")
		if not pallet then
			pallet = spawntoy("PalletLightBrown", hrp.CFrame * CFrame.new(0, 1e18, 0))
			if not pallet then return end
		end
		pallet.Name = "RagdollPallet"
		for _, p in ipairs(pallet:GetDescendants()) do
			if p:IsA("BasePart") then
				p.CanCollide = false
				p.Transparency = 1
				p.Size = Vector3.new(0.3, 0.3, 0.3)
			end
		end
		pallet.SoundPart.CFrame = targetHRP.CFrame
		task.wait()
		pallet.SoundPart.CFrame = CFrame.new(0, 1e18, 0)
	end
end)











