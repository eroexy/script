local KickNotifyConn

Tab:AddToggle({
	Name = "Kick Notifications",
	Default = true,
	Flag = "KickNotifcations",
	Save = true,
	Color = Color3.fromRGB(93, 5, 97),
	Callback = function(Value)
		if Value then
			if KickNotifyConn then
				KickNotifyConn:Disconnect()
				KickNotifyConn = nil
			end
			KickNotifyConn = Players.PlayerRemoving:Connect(function(kplr)
				if workspace:FindFirstChild("BlackHoleKick") then
					KickedPlayers[kplr] = true
					Orion:MakeNotification({Name = "Notification", Content = "Player Kicked: "..kplr.Name, Time = 5})
					workspace.BlackHoleKick.Name = kplr.Name.."KICK"
					task.delay(2, function()
						KickedPlayers[kplr] = nil
					end)
				end
			end)
		else
			if KickNotifyConn then
				KickNotifyConn:Disconnect()
				KickNotifyConn = nil
			end
		end
	end
})

Players.PlayerAdded:Connect(function(player)
	if Flags.PlayerNotifcations and not IsFriend(player) then
		Orion:MakeNotification({Name = "Notification", Content = "Player joined: "..player.Name, Time = 5})
	end

	if Target and player.Name == Target and Flags.TargetNotifcations then
		Orion:MakeNotification({Name = "Notification", Content = "Target joined: "..player.Name, Time = 5})
	end

	if Flags.FriendNotifcations and IsFriend(player) then
		Orion:MakeNotification({Name = "Notification", Content = "Friend joined: "..player.Name, Time = 5})
	end
end)

Players.PlayerRemoving:Connect(function(player)
	if KickedPlayers[player] then return end

	if Flags.PlayerNotifcations and not IsFriend(player) then
		Orion:MakeNotification({Name = "Notification", Content = "Player left: "..player.Name, Time = 5})
	end

	if Target and player.Name == Target and Flags.TargetNotifcations then
		Orion:MakeNotification({Name = "Notification", Content = "Target left: "..player.Name, Time = 5})
	end

	if Flags.FriendNotifcations and IsFriend(player) then
		Orion:MakeNotification({Name = "Notification", Content = "Friend left: "..player.Name, Time = 5})
	end
end)
