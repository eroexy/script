local function getWhitelistedPlayers()
	if not _G.WhitelistFriendsToggle then
		return {}
	end

	local whitelist = {}

	if typeof(WhitelistPlayers) == "table" then
		for k, v in pairs(WhitelistPlayers) do
			local name = nil

			if typeof(k) == "number" then
				name = v
			elseif typeof(k) == "string" and v == true then
				name = k
			end

			if typeof(name) == "string" then
				whitelist[name] = true
			end
		end
	elseif typeof(WhitelistPlayers) == "string" then
		whitelist[WhitelistPlayers] = true
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local ok, isFriend = pcall(function()
				return player:IsFriendsWith(plr.UserId)
			end)

			if ok and isFriend then
				whitelist[plr.Name] = true
			end
		end
	end

	return whitelist
end

