antiblob = false
antiblobConnection = nil

local function getChar()
	return player.Character
end

local function getHRP(char)
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function createTruePosPart(char)
	local tp = char:FindFirstChild("TruePositionPart")
	if tp then return tp end

	tp = Instance.new("Part")
	tp.Name = "TruePositionPart"
	tp.Anchored = true
	tp.CanCollide = false
	tp.Transparency = 1
	tp.Size = Vector3.new(1,1,1)
	tp.CFrame = CFrame.new(0, -100, 0)
	tp.Parent = char

	return tp
end

local function dropFromBlobs(hrp)
	for _, plot in pairs(Workspace.PlotItems:GetChildren()) do
		if plot.Name ~= "PlayersInPlots" then
			for _, itm in pairs(plot:GetChildren()) do
				if itm.Name == "CreatureBlobman" then
					pcall(function()
						local script = itm:FindFirstChild("BlobmanSeatAndOwnerScript")
						local detector = itm:FindFirstChild("RightDetector")

						if script and detector then
							local drop = script:FindFirstChild("CreatureDrop")
							local weld = detector:FindFirstChild("RightWeld")

							if drop and weld then
								drop:FireServer(weld, hrp)
								ReplicatedStorage.CharacterEvents.Struggle:FireServer(player)
							end
						end
					end)
				end
			end
		end
	end

	for _, plr in pairs(Players:GetPlayers()) do
		local toys = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
		if toys then
			for _, itm in pairs(toys:GetChildren()) do
				if itm.Name == "CreatureBlobman" then
					pcall(function()
						local script = itm:FindFirstChild("BlobmanSeatAndOwnerScript")
						local detector = itm:FindFirstChild("RightDetector")

						if script and detector then
							local drop = script:FindFirstChild("CreatureDrop")
							local weld = detector:FindFirstChild("RightWeld")

							if drop and weld then
								drop:FireServer(weld, hrp)
								ReplicatedStorage.CharacterEvents.Struggle:FireServer(player)
							end
						end
					end)
				end
			end
		end
	end
end

local function setMassless(char, hrp)
	for _, prt in pairs(char:GetChildren()) do
		if prt:IsA("BasePart") and prt.Massless then
			prt.Massless = false
			dropFromBlobs(hrp)
		end
	end
end

local function moveRootAttachment(char, hrp, truePart)
	local rootAttachment = hrp:FindFirstChild("RootAttachment")
	if rootAttachment and not truePart:FindFirstChild("RootAttachment") then
		task.wait(0.2)
		rootAttachment.Parent = truePart
	end
end

local function restoreRootAttachment(char)
	local hrp = getHRP(char)
	local truePart = char and char:FindFirstChild("TruePositionPart")

	if hrp and truePart then
		local rootAttachment = truePart:FindFirstChild("RootAttachment")
		if rootAttachment then
			rootAttachment.Parent = hrp
		end
		truePart:Destroy()
	end
end

local function antiblobLoop()
	while antiblob do
		local char = getChar()
		if char then
			local hrp = getHRP(char)
			if hrp then
				local truePart = createTruePosPart(char)
				setMassless(char, hrp)
				moveRootAttachment(char, hrp, truePart)
			end
		end
		task.wait(0.1)
	end
end

