-->>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
-- Loop Kick V2 ownership
-->>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

_G.GRAB_RATE = 0.0008
_G.DESTROY_RATE = 0.0001
_G.LoopKickOwnershipToggle = false

hrp = nil
targetHRP = nil
currentTargetPlr = nil
isGrabbing = false
savedCFrame = nil

grabConnection = nil
mainLoopRunning = false

lastGrab = 0
lastDestroy = 0

local function setupCharacter(char)
    hrp = char:WaitForChild("HumanoidRootPart")
end

player.CharacterAdded:Connect(setupCharacter)
if player.Character then
    setupCharacter(player.Character)
end

local function ownsHead(char)
    local head = char and char:FindFirstChild("Head")
    if not head then return false end
    local owner = head:FindFirstChild("PartOwner")
    return owner and owner.Value == player.Name
end

local function updateSavedCFrame()
    if hrp then
        savedCFrame = hrp.CFrame
    end
end

local function stopGrabLoop()
    if grabConnection then
        grabConnection:Disconnect()
        grabConnection = nil
    end
end

local function isTargetValid()
    if not currentTargetPlr or not currentTargetPlr.Parent then return false end

    local char = currentTargetPlr.Character
    if not char then return false end

    local hum = char:FindFirstChild("Humanoid")
    local tHRP = char:FindFirstChild("HumanoidRootPart")

    if not hum or hum.Health <= 0 then return false end
    if not tHRP then return false end
    if isInPlot and isInPlot(currentTargetPlr) then return false end

    return true
end

local function releaseTarget(skipReturn)
    stopGrabLoop()

    if targetHRP and targetHRP.Parent then
        local hum = targetHRP.Parent:FindFirstChild("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.Sit = false
        end
    end

    isGrabbing = false
    targetHRP = nil
    currentTargetPlr = nil

    if not skipReturn and hrp and savedCFrame then
        hrp.CFrame = savedCFrame
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
end

local function startGrabLoop()
    if grabConnection then return end

    grabConnection = RunService.Heartbeat:Connect(function()
        if not _G.LoopKickOwnershipToggle or not isGrabbing or not isTargetValid() then
            releaseTarget(true)
            return
        end

        if not targetHRP or not targetHRP.Parent or not hrp then
            releaseTarget(true)
            return
        end

        local char = targetHRP.Parent
        local hum = char:FindFirstChild("Humanoid")

        if not ownsHead(char) then
            pcall(function()
                SetOwner:FireServer(targetHRP, targetHRP.CFrame)
            end)
            return
        end

        local lockPos = hrp.CFrame * CFrame.new(0, 15, 0) -- fixed: follows you

        targetHRP.CFrame = lockPos
        targetHRP.AssemblyLinearVelocity = Vector3.zero
        targetHRP.AssemblyAngularVelocity = Vector3.zero

        if hum then
            hum.PlatformStand = true
            hum.Sit = false
        end

        local now = os.clock()

        if now - lastGrab >= _G.GRAB_RATE then
            pcall(function()
                SetOwner:FireServer(targetHRP, lockPos)
                CreateLine:FireServer(targetHRP, Vector3.zero, targetHRP.Position, false)
            end)
            lastGrab = now
        end

        if now - lastDestroy >= _G.DESTROY_RATE then
            pcall(function()
                DestroyLine:FireServer(targetHRP)
                CreateLine:FireServer(targetHRP, Vector3.zero, targetHRP.Position, false)
            end)
            lastDestroy = now
        end
    end)
end

local function grabPlayer(plr)
    if not plr or not plr.Character then return end

    releaseTarget(true)

    local char = plr.Character
    local tHRP = char:FindFirstChild("HumanoidRootPart")
    if not tHRP or not hrp then return end

    updateSavedCFrame()
    local returnCFrame = hrp.CFrame -- save position before teleporting

    currentTargetPlr = plr

    local distance = (tHRP.Position - hrp.Position).Magnitude

    if distance > 20 then
        hrp.CFrame = tHRP.CFrame * CFrame.new(0, 0, 3)
        task.wait(0.1)
    end

    while _G.LoopKickOwnershipToggle and not ownsHead(char) and tHRP.Parent do
        pcall(function()
            SetOwner:FireServer(tHRP, tHRP.CFrame)
            CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
        end)
        task.wait(0.005)
    end

    if not _G.LoopKickOwnershipToggle then return end

    local lockPos = hrp.CFrame * CFrame.new(0, 15, 0)
    tHRP.CFrame = lockPos
    tHRP.AssemblyLinearVelocity = Vector3.zero
    tHRP.AssemblyAngularVelocity = Vector3.zero

    for i = 1, 8 do
        pcall(function()
            SetOwner:FireServer(tHRP, lockPos)
            CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
        end)
        task.wait(0.005)
    end

    hrp.CFrame = returnCFrame
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    targetHRP = tHRP
    isGrabbing = true

    startGrabLoop()
end

local function startMainLoop()
    if mainLoopRunning then return end
    mainLoopRunning = true

    task.spawn(function()
        while _G.LoopKickOwnershipToggle do
            task.wait(0.1)

            if not Target then
                releaseTarget(true)
                continue
            end

            local plr
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Name == Target or p.DisplayName == Target then
                    plr = p
                    break
                end
            end

            if not plr then
                releaseTarget(true)
                continue
            end

            if isInPlot and isInPlot(plr) then
                releaseTarget(true)
                continue
            end

            local char = plr.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local tHRP = char and char:FindFirstChild("HumanoidRootPart")

            if not char or not hum or hum.Health <= 0 or not tHRP then
                releaseTarget(true)

                repeat
                    task.wait(0.5)
                    char = plr.Character
                    hum = char and char:FindFirstChild("Humanoid")
                until not _G.LoopKickOwnershipToggle or (hum and hum.Health > 0)

                continue
            end

            if not isGrabbing then
                updateSavedCFrame()
                grabPlayer(plr)
            end

            if isGrabbing and not isTargetValid() then
                releaseTarget(true)
            end
        end

        mainLoopRunning = false
    end)
end

