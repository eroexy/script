_G.LoopKillOwnershipToggle = false
_G.LoopKillAllOwnershipToggle = false
_G.LoopKickV1 = false
_G.LoopKickAllV1 = false

currentTargetPlr = nil
targetHRP = nil
isGrabbing = false
savedPos = nil
mainLoopRunning = false

local function updateSavedPosition()
	if hrp and hrp.Parent then
		savedPos = hrp.CFrame
	end
end

local function isInPlot(plr)
	if not plr then return false end
	local folder = Workspace:FindFirstChild("PlotItems")
	if not folder then return false end
	local playersInPlots = folder:FindFirstChild("PlayersInPlots")
	if not playersInPlots then return false end
	return playersInPlots:FindFirstChild(plr.Name) ~= nil
end

local function isTargetWorthTracking(plr, maxDist)
	if not plr or not plr.Character then return false end
	if isInPlot(plr) then return false end                     -- Skip if in plot

	local hrpT = plr.Character:FindFirstChild("HumanoidRootPart")
	if not hrpT then return false end

	local myHRP = hrp
	if not myHRP then return false end

	local dist = (hrpT.Position - myHRP.Position).Magnitude
	return dist <= (maxDist or 1500)
end

-- Check distance from original saved position
local function isWithinSavedPosRange(plr, maxDist)
	if not savedPos or not plr or not plr.Character then return false end
	local hrpT = plr.Character:FindFirstChild("HumanoidRootPart")
	if not hrpT then return false end

	local dist = (hrpT.Position - savedPos.Position).Magnitude
	return dist <= (maxDist or 1500)
end

local function GetClosestTarget(maxDist)
	local myHRP = hrp
	if not myHRP then return nil end

	local closest = nil
	local closestDist = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == player then continue end
		if WhitelistPlayers and WhitelistPlayers[plr.Name] then continue end
		if isInPlot(plr) then continue end                          -- Extra safety

		if isTargetWorthTracking(plr, maxDist) and isWithinSavedPosRange(plr, 1500) then
			local tHRP = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
			if tHRP then
				local dist = (tHRP.Position - myHRP.Position).Magnitude
				if dist < closestDist then
					closest = plr
					closestDist = dist
				end
			end
		end
	end
	return closest
end

local function releaseTarget()
	if targetHRP and targetHRP.Parent then
		local hum = targetHRP.Parent:FindFirstChild("Humanoid")
		if hum then
			hum.PlatformStand = false
			hum.Sit = false
		end
	end
	isGrabbing = false
	targetHRP = nil
	currentTargetPlr = nil
end

local function releaseTargetAll()
	releaseTarget()
end

local function PerformOwnershipAction(plr, isKillMode)
	if not plr or not plr.Character or isInPlot(plr) then 
		isGrabbing = false 
		return 
	end

	local tChar = plr.Character
	local tHRP = tChar:FindFirstChild("HumanoidRootPart")
	if not tHRP then 
		isGrabbing = false 
		return 
	end

	updateSavedPosition()
	local mySaved = savedPos
	currentTargetPlr = plr
	targetHRP = tHRP

	local distance = (tHRP.Position - hrp.Position).Magnitude
	local start = tick()

	while (_G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle or 
		_G.LoopKickV1 or _G.LoopKickAllV1) do
		if distance <= 20 then break end
		if not tHRP.Parent then break end

		hrp.CFrame = tHRP.CFrame
		distance = (tHRP.Position - hrp.Position).Magnitude

		if tick() - start > 0.15 then break end
		task.wait()
	end

	if not (_G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle or 
		_G.LoopKickV1 or _G.LoopKickAllV1) or not tHRP.Parent then 
		isGrabbing = false 
		return 
	end

	task.wait()

	for i = 1, 16 do
		if not (_G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle or 
			_G.LoopKickV1 or _G.LoopKickAllV1) then 
			break 
		end

		pcall(function()
			SetOwner:FireServer(tHRP, tHRP.CFrame)
			CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
		end)
		task.wait(0.01)
	end

	if not (_G.LoopKillOwnershipToggle or _G.LoopKillAllOwnershipToggle or 
		_G.LoopKickV1 or _G.LoopKickAllV1) then 
		isGrabbing = false 
		return 
	end

	local launchPos = mySaved * CFrame.new(0, 1e18, 0)

	if isKillMode then
		tHRP.CFrame = launchPos
		tHRP.AssemblyLinearVelocity = Vector3.zero
		tHRP.AssemblyAngularVelocity = Vector3.zero

		pcall(function()
			DestroyLine:FireServer(tHRP)
			CreateLine:FireServer(tHRP, Vector3.zero, tHRP.Position, false)
		end)

		task.wait()

		local tHum = tChar:FindFirstChild("Humanoid")
		if tHum then
			tHum.BreakJointsOnDeath = false
			task.wait()
			tHum.Health = 0
		end
	else
		pcall(function()
			tHRP.CFrame = launchPos
			tHRP.AssemblyLinearVelocity = Vector3.zero
			tHRP.AssemblyAngularVelocity = Vector3.zero
		end)
		pcall(function()
			DestroyLine:FireServer(tHRP)
		end)
	end

	if hrp and mySaved then
		hrp.CFrame = mySaved
	end

	releaseTarget()
end

local function StartLoopKill()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKillOwnershipToggle do
			task.wait()
			if not Target then continue end

			local plr = nil
			for _, p in ipairs(Players:GetPlayers()) do
				if p.Name == Target or p.DisplayName == Target then
					plr = p
					break
				end
			end

			if not plr or plr == player or isInPlot(plr) or not isTargetWorthTracking(plr) then
				releaseTarget()
				continue
			end

			if not isGrabbing then
				isGrabbing = true
				PerformOwnershipAction(plr, true)
			end
		end
		releaseTarget()
		mainLoopRunning = false
	end)
end

local function StartLoopKillAll()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKillAllOwnershipToggle do
			task.wait(0.005)
			if isGrabbing then continue end

			local plr = GetClosestTarget()
			if not plr then continue end

			isGrabbing = true
			PerformOwnershipAction(plr, true)
		end
		releaseTargetAll()
		mainLoopRunning = false
	end)
end

local function StartLoopKickV1()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKickV1 do
			task.wait(0.1)
			if not Target or typeof(Target) ~= "string" then continue end

			local plr = nil
			for _, p in ipairs(Players:GetPlayers()) do
				if p.Name == Target or p.DisplayName == Target then
					plr = p
					break
				end
			end

			if not plr or plr == player or isInPlot(plr) or not isTargetWorthTracking(plr) then
				releaseTarget()
				continue
			end

			if not isGrabbing then
				isGrabbing = true
				PerformOwnershipAction(plr, false)
			end
		end
		releaseTarget()
		mainLoopRunning = false
	end)
end

local function StartLoopKickAllV1()
	if mainLoopRunning then return end
	mainLoopRunning = true

	task.spawn(function()
		while _G.LoopKickAllV1 do
			task.wait(0.005)
			if isGrabbing then continue end

			local plr = GetClosestTarget()
			if not plr then continue end

			isGrabbing = true
			PerformOwnershipAction(plr, false)
		end
		releaseTargetAll()
		mainLoopRunning = false
	end)
end

